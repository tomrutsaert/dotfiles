// Personal Zellij configuration managed by GNU Stow from the dotfiles repo.
//
// Keep this file focused on deliberate overrides. Zellij's built-in defaults
// provide the full keymap, plugin aliases, and tmux-mode bindings.

theme "dotfiles"
default_layout "default"
default_mode "normal"

pane_frames true
auto_layout true
mouse_mode true
scroll_buffer_size 10000

copy_clipboard "system"
copy_on_select true

on_force_close "detach"
session_serialization true
serialize_pane_viewport false

simplified_ui true
show_release_notes false
show_startup_tips false

// Codex CLI expects the literal CSI-u sequence sent by the terminal for
// Shift+Enter. Zellij's Kitty keyboard protocol mode consumes that sequence
// before it reaches the pane.
support_kitty_keyboard_protocol false

// Keep web sharing opt-in only.
web_server false
web_sharing "off"

// Keep the default keybindings, including Ctrl-b tmux mode, and add a few
// direct split shortcuts that mirror the tmux config muscle memory.
keybinds {
    tmux {
        bind "1" { GoToTab 1; SwitchToMode "Normal"; }
        bind "2" { GoToTab 2; SwitchToMode "Normal"; }
        bind "3" { GoToTab 3; SwitchToMode "Normal"; }
        bind "4" { GoToTab 4; SwitchToMode "Normal"; }
        bind "5" { GoToTab 5; SwitchToMode "Normal"; }
        bind "6" { GoToTab 6; SwitchToMode "Normal"; }
        bind "7" { GoToTab 7; SwitchToMode "Normal"; }
        bind "8" { GoToTab 8; SwitchToMode "Normal"; }
        bind "9" { GoToTab 9; SwitchToMode "Normal"; }
    }

    shared_except "locked" {
        bind "Alt |" { NewPane "Right"; }
        bind "Alt -" { NewPane "Down"; }
    }
}
